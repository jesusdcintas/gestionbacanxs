---
import '../styles/global.css';
import { NavShell } from '../components/layout/NavShell';

interface Props {
  title?: string;
  userName?: string;
}

const { title = 'Gestor Bacanxs', userName = 'Usuario' } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content={Astro.generator} name="generator" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo-bacanxs.png" />
    <link rel="apple-touch-icon" href="/logo-bacanxs.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0a0a0a] text-text-primary antialiased">
    <NavShell pathname={pathname} userName={userName} client:load />
    <div class="min-h-screen pl-0 md:pl-60">
      <main class="p-4 md:p-6">
        <slot />
      </main>
    </div>
  </body>
</html>
