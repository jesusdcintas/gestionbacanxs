---
import AppLayout from '../../layouts/AppLayout.astro';
import IngresosTable from '../../components/ingresos/IngresosTable.tsx';
import { Button } from '../../components/ui/Button.tsx';
import { Card } from '../../components/ui/Card.tsx';
import { Plus } from 'lucide-react';
import { getIngresos } from '../../services/ingresos';

const ingresos = await getIngresos(Astro);
---

<AppLayout title="Ingresos">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl uppercase italic" style="font-family: 'Archivo Black', sans-serif;">Ingresos</h1>
        <p class="text-text-secondary mt-1">Registra tus entradas de dinero</p>
      </div>
      <a href="/ingresos/nuevo">
        <Button variant="primary" client:load>
          <Plus size={20} />
          Nuevo Ingreso
        </Button>
      </a>
    </div>

    <Card>
      <IngresosTable ingresos={ingresos} editBasePath="/ingresos" client:load />
    </Card>
  </div>
</AppLayout>
