---
import AppLayout from '../../layouts/AppLayout.astro';
import GastoForm from '../../components/gastos/GastoForm.tsx';
import { getGasto, updateGasto } from '../../services/gastos';
import { getEventos } from '../../services/eventos';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/gastos');
}

let gasto;
try {
  gasto = await getGasto(Astro, id);
} catch (error) {
  console.error('Error loading gasto:', error);
  return Astro.redirect('/gastos');
}

const eventos = await getEventos(Astro);

// Handle form submission
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    const gastoData = {
      concepto: formData.get('concepto')?.toString() || '',
      cantidad: parseFloat(formData.get('cantidad')?.toString() || '0'),
      categoria: formData.get('categoria')?.toString() || 'Otros',
      fecha: formData.get('fecha')?.toString() || new Date().toISOString().split('T')[0],
      evento_id: formData.has('evento_id') && formData.get('evento_id') ? formData.get('evento_id')!.toString() : null,
    };

    console.log('Datos del gasto a actualizar:', JSON.stringify(gastoData, null, 2));
    
    await updateGasto(Astro, id, gastoData);
    return Astro.redirect('/gastos');
  } catch (error) {
    console.error('Error updating gasto:', error);
    const errorMessage = error instanceof Error ? error.message : 'Error desconocido';
    return new Response(
      `<html><body><h1>Error al actualizar gasto</h1><pre>${errorMessage}</pre><a href="/gastos/${id}">Volver</a></body></html>`,
      { status: 500, headers: { 'Content-Type': 'text/html' } }
    );
  }
}
---

<AppLayout title={`Editar ${gasto.concepto}`}>
  <div class="max-w-3xl mx-auto space-y-6">
    <div>
      <h1 class="text-3xl uppercase italic" style="font-family: 'Archivo Black', sans-serif;">Editar gasto</h1>
      <p class="text-text-secondary mt-1">Modifica los detalles del gasto</p>
    </div>

    <GastoForm gasto={gasto} eventos={eventos} client:load />
  </div>
</AppLayout>
