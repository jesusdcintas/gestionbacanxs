---
import AppLayout from '../layouts/AppLayout.astro';
import { Card, CardHeader, CardTitle, CardContent } from '../components/ui/Card.tsx';
import { StampLabel } from '../components/ui/StampLabel.tsx';
import MonthlyChart from '../components/balance/MonthlyChart.tsx';
import CategoryChart from '../components/balance/CategoryChart.tsx';
import BalanceSociosTable from '../components/balance/BalanceSociosTable.tsx';
import GastosPendientesList from '../components/balance/GastosPendientesList.tsx';
import {
  getBalanceData,
  getCategoryData,
  getBalanceSocios,
  getAllGastosPendientes,
} from '../services/balance';

const [monthlyData, categoryData, balanceSocios, gastosPendientes] = await Promise.all([
  getBalanceData(Astro, 6),
  getCategoryData(Astro),
  getBalanceSocios(Astro),
  getAllGastosPendientes(Astro),
]);

const totalIngresos = monthlyData.reduce((sum, m) => sum + m.ingresos, 0);
const totalGastos = monthlyData.reduce((sum, m) => sum + m.gastos, 0);
const beneficio = totalIngresos - totalGastos;

const formatCurrency = (value: number) =>
  new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(value);
---

<AppLayout title="Balance">
  <div class="space-y-8">
    <!-- Encabezado -->
    <div>
      <p class="text-[11px] uppercase tracking-[0.24em] text-text-secondary">Balance</p>
      <h1
        class="mt-2 text-3xl uppercase italic"
        style="font-family: 'Archivo Black', sans-serif;"
      >
        Balance financiero
      </h1>
      <p class="text-text-secondary mt-1">
        Ingresos y gastos en el tiempo, balance entre socios y reembolsos pendientes.
      </p>
    </div>

    <!-- Métricas globales 6 meses -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="border border-border bg-surface p-5">
        <p class="text-[11px] uppercase tracking-[0.08em] text-text-secondary">Ingresos (6m)</p>
        <p
          class="mt-2 text-2xl font-semibold text-text-primary"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          {formatCurrency(totalIngresos)}
        </p>
      </div>
      <div class="border border-border bg-surface p-5">
        <p class="text-[11px] uppercase tracking-[0.08em] text-text-secondary">Gastos (6m)</p>
        <p
          class="mt-2 text-2xl font-semibold text-danger"
          style="font-family: 'JetBrains Mono', monospace;"
        >
          −{formatCurrency(totalGastos)}
        </p>
      </div>
      <div class="border border-border bg-surface p-5">
        <p class="text-[11px] uppercase tracking-[0.08em] text-text-secondary">Beneficio (6m)</p>
        <p
          class={`mt-2 text-2xl font-semibold ${beneficio >= 0 ? 'text-accent' : 'text-danger'}`}
          style="font-family: 'JetBrains Mono', monospace;"
        >
          {beneficio >= 0 ? '+' : '−'}{formatCurrency(Math.abs(beneficio))}
        </p>
      </div>
    </div>

    <!-- Balance entre socios -->
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <StampLabel rotate="left" variant="accent">Socios</StampLabel>
        <h2
          class="text-xl uppercase italic"
          style="font-family: 'Archivo Black', sans-serif;"
        >
          Balance entre socios
        </h2>
      </div>

      <Card>
        <CardContent>
          <BalanceSociosTable balances={balanceSocios} />
        </CardContent>
      </Card>
    </div>

    <!-- Reembolsos pendientes -->
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <StampLabel rotate="right" variant="danger">Reembolsos</StampLabel>
        <h2
          class="text-xl uppercase italic"
          style="font-family: 'Archivo Black', sans-serif;"
        >
          Gastos pendientes de reembolso
        </h2>
      </div>

      <Card>
        <CardContent>
          <GastosPendientesList gastos={gastosPendientes} client:load />
        </CardContent>
      </Card>
    </div>

    <!-- Histórico mensual y categorías -->
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <StampLabel rotate="left" variant="outline">Histórico</StampLabel>
        <h2
          class="text-xl uppercase italic"
          style="font-family: 'Archivo Black', sans-serif;"
        >
          Evolución y categorías
        </h2>
      </div>

      <Card>
        <CardHeader>
          <CardTitle>Ingresos vs gastos · Últimos 6 meses</CardTitle>
        </CardHeader>
        <CardContent>
          <MonthlyChart data={monthlyData} client:load />
        </CardContent>
      </Card>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <Card>
          <CardHeader>
            <CardTitle>Gastos por categoría</CardTitle>
          </CardHeader>
          <CardContent>
            <CategoryChart data={categoryData} client:load />
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Resumen por categoría</CardTitle>
          </CardHeader>
          <CardContent>
            {categoryData.length === 0 ? (
              <p class="text-sm text-text-secondary text-center py-8">
                Aún no hay gastos registrados.
              </p>
            ) : (
              <div class="space-y-1">
                {categoryData.map((cat) => (
                  <div
                    class="flex items-center justify-between py-2 border-b border-border last:border-0"
                  >
                    <span class="text-[11px] uppercase tracking-[0.08em] text-text-primary">
                      {cat.categoria}
                    </span>
                    <div class="flex items-center gap-3">
                      <div
                        class="text-xs text-text-secondary"
                        style="font-family: 'JetBrains Mono', monospace;"
                      >
                        {cat.porcentaje.toFixed(1)}%
                      </div>
                      <div
                        class="text-sm text-danger min-w-25 text-right"
                        style="font-family: 'JetBrains Mono', monospace;"
                      >
                        −{formatCurrency(cat.total)}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</AppLayout>
